# ClearBot worker — required env vars
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Envelope-encryption master key. AES-256, 32 bytes (hex or base64).
# Generate locally:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the value used by the Next app (otherwise worker can't
# decrypt portal_credentials rows that the dashboard wrote).
CREDENTIAL_MASTER_KEY=

# Optional knobs
# WORKER_POLL_MS=2000
# WORKER_STALE_LEASE_SECONDS=600
# WORKER_STALE_SWEEP_MS=60000
# WORKER_RETRY_BASE_MS=60000
