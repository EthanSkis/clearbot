# Supabase — get these from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side service role key (bypasses RLS — used by cron routes and
# the public API authenticator). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Cron auth bearer. Vercel Cron sends this automatically when set.
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Envelope-encryption master key for portal_credentials.
# AES-256, 32 bytes (hex or base64). Same generator as CRON_SECRET.
CREDENTIAL_MASTER_KEY=

# Public app URL (used in renewal email links etc.).
NEXT_PUBLIC_APP_URL=https://clearbot.io

# SMTP (Zoho) — used to send booking confirmation / notification emails.
# These are server-only. For Zoho: smtp.zoho.com (or smtp.zoho.eu) : 465 (SSL) or 587 (STARTTLS).
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ClearBot <ethan@clearbot.io>"

# Where booking notifications get sent internally.
BOOKING_NOTIFICATION_TO=ethan@clearbot.io
